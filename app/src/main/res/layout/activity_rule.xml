<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:fitsSystemWindows="true">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar" android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize" android:background="@color/primary"
            app:title="@string/add_rule" app:titleTextColor="@color/on_primary"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/on_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent" android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- 设备信息 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" app:cardElevation="2dp" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/name_layout" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                        android:hint="@string/rule_name" app:startIconDrawable="@drawable/ic_label">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/name" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:inputType="text" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/mac_layout" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginBottom="8dp"
                        android:hint="@string/device_mac" app:startIconDrawable="@drawable/ic_mac"
                        app:placeholderText="@string/mac_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/mac" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:inputType="text" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/import_paired"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/import_paired" app:icon="@drawable/ic_bluetooth" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:hint="@string/device_name_filter"
                        app:startIconDrawable="@drawable/ic_filter">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/device_name_filter" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:inputType="text" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 命令 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" app:cardElevation="2dp" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp" android:hint="@string/above_command"
                        app:startIconDrawable="@drawable/ic_arrow_up"
                        app:placeholderText="@string/command_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/above_command" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:inputType="textMultiLine"
                            android:gravity="top" android:minLines="2" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="@string/below_command"
                        app:startIconDrawable="@drawable/ic_arrow_down"
                        app:placeholderText="@string/command_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/below_command" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:inputType="textMultiLine"
                            android:gravity="top" android:minLines="2" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 启用 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardElevation="2dp" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/enable"
                        android:textColor="@color/on_surface" android:textSize="16sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/enable_switch" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button android:id="@+id/save" android:layout_width="match_parent"
                android:layout_height="48dp" android:text="@string/save" android:textSize="16sp"
                android:backgroundTint="@color/primary" android:textColor="@color/on_primary"
                app:cornerRadius="8dp" />
            <Button android:id="@+id/delete" android:layout_width="match_parent"
                android:layout_height="48dp" android:layout_marginTop="8dp"
                android:text="@string/delete" android:textSize="16sp"
                android:backgroundTint="@color/error" android:textColor="@color/on_primary"
                android:visibility="gone" app:cornerRadius="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
